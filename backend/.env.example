PORT=8788
BACKEND_PUBLIC_BASE_URL=https://api.example.com

# Plaid. Use sandbox for development.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=
PLAID_ANDROID_PACKAGE_NAME=com.renewalradar.app

# Required outside local mock development. 32-byte key as base64 is preferred.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_TOKEN_ENCRYPTION_KEY=

# Development controls.
PLAID_MOCK_MODE=true
SEED_MOCK_DATA=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
